  "servicesContent": {
    "serviceContent": {
      "description": "Beyond just juice, we provide health, happiness, and convenience\n\nExplore how VanJuice can be a part of your daily life."
    },
    "services": [
      {
        "id": 1,
        "iconName": "truck",
        "title": "Fast Delivery",
        "description": "Get your fresh juices delivered to your doorstep in record time. We ensure the cold chain is maintained so your drink arrives icy fresh!"
      },
      {
        "id": 2,
        "iconName": "heart",
        "title": "100% Organic",
        "description": "We source our fruits directly from local organic farmers. No added sugars, no preservatives, just pure nature in a bottle."
      },
      {
        "id": 3,
        "iconName": "gift",
        "title": "Gift Baskets",
        "description": "Show you care with our customizable wellness gift baskets. Perfect for birthdays, get-well-soon gifts, or corporate events."
      },
